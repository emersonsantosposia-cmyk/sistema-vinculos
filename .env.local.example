# Copie este arquivo para .env.local e preencha com as chaves do seu projeto Supabase.
# Obtenha em: https://supabase.com/dashboard → Project Settings → API
#
# Teste fail-closed (I3): comente as DUAS linhas ATIVAS abaixo (as que
# começam com NEXT_PUBLIC_… sem #), salve, APAGUE a pasta .next e rode
# `npm run dev` de novo. /login deve redirecionar para /indisponivel.

NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Domínio institucional de e-mail (login abreviado).
# Na tela de login o usuário digita só a parte antes do @ (ex: emerson.santos);
# o sistema completa com @ + este domínio antes de autenticar no Supabase.
# Se o usuário digitar o e-mail completo, ele é usado como está.
NEXT_PUBLIC_EMAIL_DOMAIN=mj.gov.br

# Service role (secret): API de usuários (/api/usuarios) e scripts admin.
# Nunca exponha no frontend. Em: Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-aqui

# Mapas: o sistema usa Leaflet + OpenStreetMap (sem chave obrigatória).
# Geocodificação via Nominatim (OSM).
#
# Se no futuro migrar para Google Maps, adicione:
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=sua-chave
# Gerar em: https://console.cloud.google.com/ → APIs e serviços → Credenciais
# Habilitar: Maps JavaScript API + Geocoding API
