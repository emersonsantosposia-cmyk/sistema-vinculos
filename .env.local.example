# Copie este arquivo para .env.local e preencha com as chaves do seu projeto Supabase.
# Obtenha em: https://supabase.com/dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Mapas: o sistema usa Leaflet + OpenStreetMap (sem chave obrigatória).
# Geocodificação via Nominatim (OSM).
#
# Se no futuro migrar para Google Maps, adicione:
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=sua-chave
# Gerar em: https://console.cloud.google.com/ → APIs e serviços → Credenciais
# Habilitar: Maps JavaScript API + Geocoding API
