{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Abrir app no login",
      "type": "process",
      "command": "${workspaceFolder}\\.vscode\\open-login.cmd",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "echo": false,
        "close": true,
        "panel": "shared",
        "showReuseMessage": false,
        "focus": false
      }
    }
  ]
}
